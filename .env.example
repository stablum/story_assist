# Copy this file to `.env` and fill the values.
# APP_API_TOKEN is required to use API endpoints.
APP_API_TOKEN=change-this-to-a-long-random-token

# Comma-separated list for browser CORS access.
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000

# Optional runtime limits
MAX_STORY_SKETCH_CHARS=20000
MAX_QUESTION_PREAMBLE_CHARS=4000
MAX_QUESTIONS=12
MAX_QUESTION_CHARS=600
MAX_ACTIVE_JOBS=30
MAX_CONCURRENT_JOBS=4
MAX_PARALLEL_QUESTIONS_PER_JOB=4
MAX_GLOBAL_PARALLEL_QUESTIONS=16
MAX_JOB_CREATIONS_PER_MINUTE=20
PROVIDER_TIMEOUT_SECONDS=90
MAX_OUTPUT_TOKENS=1600

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
